# 🔥 Performance and smooth rendering
enable_audio_bell no
scrollback_lines 10000
input_delay 3
sync_to_monitor no
scrollback_lines 10000
scrollback_pager less
scroll_on_output no
scroll_on_input no
mouse_hide_wait 1.0

# 🔡 Font settings 
font_family FiraCode Nerd Font Mono
font_size 16
#modify_font cell_height 175%
enable_ligatures always
allow_hyperlinks yes

# 🔳 Transparency 
background_opacity 0.75

# 🖥️ Window management shortcuts
map cmd+shift+[ previous_tab
map cmd+shift+] next_tab

# 🛠️ Text rendering improvements
allow_hyperlinks yes
shell_integration enabled
bold_font auto
italic_font auto
bold_italic_font auto

# term xterm-kitty
term xterm-256color

# Allow running kitty command from nvim (https://github.com/kovidgoyal/kitty/issues/2426)
allow_remote_control yes
listen_on unix:/tmp/mykitty

# Window
hide_window_decorations titlebar-only
macos_show_window_title_in none
window_margin_width 0 3 0 3

# Transparency
background_blur 12
text_composition_strategy 1.7 30
cursor_beam_thickness 1.0
clipboard_control write-clipboard write-primary

# Theme Overrides
# bg color needs to be differnt from vim by 1 for transparency to work properly (https://github.com/dracula/vim/issues/284)
background #282c35 
foreground #abb2bf
active_border_color #00ff00
